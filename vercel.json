{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "WHATSAPP_TOKEN": "@whatsapp_token",
    "PHONE_NUMBER_ID": "@phone_number_id",
    "VERIFY_TOKEN": "@verify_token",
    "NODE_ENV": "production"
  }
}
